{
  "expo": {
    "name": "Rachaí",
    "slug": "Rachaí",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "webracha",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "Rachaí",
      "shortName": "Rachaí",
      "description": "Divida suas contas de forma fácil e rápida entre amigos.",
      "display": "standalone",
      "backgroundColor": "#E6F4FE",
      "themeColor": "#E6F4FE",
      "startUrl": "/",
      "scope": "/",
      "orientation": "portrait",
      "lang": "pt-BR"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
